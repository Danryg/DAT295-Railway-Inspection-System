    <wheelSeparation>0.5</wheelSeparation>
    <wheelRadius>0.1</wheelRadius>

    <leftJoint>front_axle_hinge</leftJoint>
    <rightJoint>back_axle_hinge</rightJoint>

    <updateRate>50.0</updateRate>
    <odomFrame>odom</odomFrame>
    <baseFrame>amp</baseFrame>
  </plugin> -->
    <!---<allow_auto_disable>1</allow_auto_disable> -->
  </model>
</sdf>