<?xml version='1.0'?>
<sdf version='1.7'>
  <model name='amp'>
    <static>false</static>

    <link name='hull'>

      <pose>0.003725 0.051897 0.000757 0 -0 0</pose>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name='back_axle'>
      <pose>0 0.8 0 0 0 0</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_axle/amp_axle.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_axle/amp_axle.obj</uri>
          </mesh>
        </geometry>
      </collision>

    </link>


    <link name='front_axle'>
      <pose>0 -0.85 0 0 0 0</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_axle/amp_axle.obj</uri>
            <scale>1 1 1</scale>
          </mesh>

        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_axle/amp_axle.obj</uri>
          </mesh>

        </geometry>
      </collision>

    </link>

    <joint type="revolute" name="front_axle_hinge">
      <pose>0 0 0 0 0 0</pose>
      <child>front_axle</child>
      <parent>hull</parent>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>

    <joint type="revolute" name="back_axle_hinge">
      <pose>0 0 0 0 0 0</pose>
      <child>back_axle</child>
      <parent>hull</parent>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>


    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <robot_namespace>/amp</robot_namespace>

      <command_topic>/cmd_vel</command_topic>

      <odometry_topic>/odom</odometry_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <wheel_separation>0.5</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>

      <left_joint>front_axle_hinge</left_joint>
      <right_joint>back_axle_hinge</right_joint>

      <update_rate>50.0</update_rate>
      <odom_frame>odom</odom_frame>
      <base_frame>amp</base_frame>

    </plugin>
    <!---<allow_auto_disable>1</allow_auto_disable> -->
  </model>
</sdf>