<?xml version='1.0'?>
<sdf version='1.7'>
  <model name='amp'>
    <static>true</static>
    <link name='hull'>

      <pose>0.003725 0.051897 0.000757 0 -0 0</pose>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name='left_back_wheel'>
      <pose>0.6 0.8 0 0 0 0</pose>


      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>
        </geometry>
      </collision>

    </link>

    <link name='right_back_wheel'>
      <pose>-0.6 0.8 0 0 0 3.14159</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>
        </geometry>
      </collision>

    </link>


    <link name='left_front_wheel'>
      <pose>0.6 -0.85 0 0 0 0</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>

        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>

        </geometry>
      </collision>

    </link>

    <link name='right_front_wheel'>
      <pose>-0.6 -0.85 0 0 0 3.14159</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>

        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>

        </geometry>
      </collision>

    </link>


    <joint type="revolute" name="front_axle_hinge">
      <pose>0 0 -0.03 0 0 0</pose>
      <child>front_axle</child>
      <parent>hull</parent>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>

    <joint type="revolute" name="back_axle_hinge">
      <pose>0 0 0.03 0 0 0</pose>
      <child>back_axle</child>
      <parent>hull</parent>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>


    <!-- <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
