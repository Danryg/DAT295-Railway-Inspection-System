<?xml version='1.0'?>
<sdf version='1.7'>
  <model name='amp'>
    <static>false</static>
    <link name='hull'>

      <pose>0.003725 0.051897 0.000757 0 -0 0</pose>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
          </mesh>
        </geometry>
      </collision>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_hull/amp_hull.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <!-- Caster for testing -->
      <collision name='caster_collision'>
        <pose>0 -0.8 -0.05 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>.1</radius>
          </sphere>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>0</mu>
              <mu2>0</mu2>
              <slip1>1.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name='caster_visual'>
        <pose>0 -0.8 -0.05 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>.1</radius>
          </sphere>
        </geometry>
      </visual>
      <!-- End Caster -->
    </link>

    <link name='left_back_wheel'>
      <pose>0.6 0.8 0 0 0 0</pose>


      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>
        </geometry>
      </collision>

    </link>

    <link name='right_back_wheel'>
      <pose>-0.6 0.8 0 0 0 3.14159</pose>

      <visual name='visual'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>model://amp_wheel/amp_wheel.obj</uri>
          </mesh>
        </geometry>
      </collision>

    </link>


